# ── Búsqueda ───────────────────────────────────────────────────────────────────
# Proveedor: serpapi | newsapi | googlepse
SEARCH_API_PROVIDER=serpapi
SEARCH_API_KEY=

# Solo si usas Google Programmable Search Engine
GOOGLE_PSE_CX=

# ── Correo SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
# Destinatarios separados por coma
EMAIL_TO=

# ── General ────────────────────────────────────────────────────────────────────
TIMEZONE=America/Santiago
DB_PATH=data/radar_prensa.db
LOG_LEVEL=INFO
